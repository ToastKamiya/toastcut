{
  "name": "toastcut",
  "version": "1.0.7",
  "description": "A lightweight OS-agnostic video editor based on FFMPEG",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ktoast.toastcut",
    "productName": "ToastCut",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "assets/**/*",
      "operations/*",
      "node_modules/ffprobe-static/bin/${platform}/**/*"
      "!dist/**/*"
    ],
    "asarUnpack": [
      "assets/bin/**/*",
      "node_modules/ffprobe-static/bin/${platform}/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "AppImage"
    },
    "toolsets": {
      "appimage": "1.0.3"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "ffprobe-static": "^3.1.0"
  }
}
